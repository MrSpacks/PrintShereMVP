# Copy to .env.local (Next.js + Prisma CLI via npm run db:*)
# DATABASE_URL and AUTH_SECRET are required.

# Neon PostgreSQL (pooled connection string)
DATABASE_URL=

# Session signing secret — generate with: openssl rand -base64 32
AUTH_SECRET=

# Vercel Blob — private storage for order STL/OBJ files (up to 50 MB).
# Client uploads (browser → Blob) REQUIRE BLOB_READ_WRITE_TOKEN.
#
# Setup:
# 1. Vercel Dashboard → Storage → Create Blob store (Private)
# 2. Connect the store to this project
# 3. Open Storage → your store → ".env.local" tab — copy BLOB_READ_WRITE_TOKEN
# 4. Project → Settings → Environment Variables — confirm BLOB_READ_WRITE_TOKEN
#    exists for Production (and Preview if you test preview URLs)
# 5. Redeploy after adding the variable
#
# Note: BLOB_STORE_ID alone is not enough for client uploads — you need the rw token.
# Without it, /api/orders/upload-mode returns mode: "server" (disk fallback, dev only).
BLOB_READ_WRITE_TOKEN=

# Stripe (optional) — enables live payment stats in /admin overview when connected.
# STRIPE_SECRET_KEY=
# STRIPE_FEE_RATE=0.014
# STRIPE_FEE_FIXED_CZK=2
