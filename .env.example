# Copy to .env.local (Next.js + Prisma CLI via npm run db:*)
# DATABASE_URL and AUTH_SECRET are required.

# Neon PostgreSQL (pooled connection string)
DATABASE_URL=

# Session signing secret — generate with: openssl rand -base64 32
AUTH_SECRET=

# Vercel Blob — private storage for order STL/OBJ files (up to 50 MB).
# 1. Vercel Dashboard → Storage → Create Blob store (choose Private)
# 2. Connect the store to this project (adds BLOB_READ_WRITE_TOKEN automatically)
# 3. For local dev: copy BLOB_READ_WRITE_TOKEN from Vercel → Project → Settings → Environment Variables
# Without this token, files are saved to storage/orders/ on disk (dev only; not for production).
BLOB_READ_WRITE_TOKEN=

# Stripe (optional) — enables live payment stats in /admin overview when connected.
# STRIPE_SECRET_KEY=
# STRIPE_FEE_RATE=0.014
# STRIPE_FEE_FIXED_CZK=2
