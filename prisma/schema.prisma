generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum MakerStatus {
  available
  busy
  hidden
}

enum StaffRole {
  moderator
  admin
}

enum OrderStatus {
  pending
  awaiting_customer
  awaiting_payment
  paid
  printing
  shipped
  delivered
  completed
  disputed
  refunded
  cancelled
}

enum PrintQuality {
  draft
  standard
  high
}

enum UserRole {
  customer
  maker
  moderator
  admin
}

enum DisputeStatus {
  open
  resolved
}

enum DisputeResolution {
  refund
  rejected
}

model User {
  id           String     @id
  email        String     @unique
  name         String
  avatarUrl    String?
  address      String?
  passwordHash String
  role         UserRole   @default(customer)
  staffRole    StaffRole?
  makerId      String?    @unique
  blockedUntil DateTime?
  maker        Maker?     @relation("ActiveWorkshop", fields: [makerId], references: [id], onDelete: SetNull)
  ownedMakers  Maker[]    @relation("MakerOwner")
  orders        Order[]
  orderMessages OrderMessage[]
  orderReadReceipts OrderReadReceipt[]
  reviews           OrderReview[]
  disputesOpened    Dispute[] @relation("DisputeOpener")
  disputesResolved  Dispute[] @relation("DisputeResolver")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([role])
  @@index([staffRole])
}

model Maker {
  id               String           @id
  ownerUserId      String
  owner            User             @relation("MakerOwner", fields: [ownerUserId], references: [id], onDelete: Cascade)
  name             String
  address          String
  latitude         Float
  longitude        Float
  rating           Float
  pricePerGramCzk  Float
  minOrderPriceCzk Int              @default(0)
  printerTypes     String[]
  status           MakerStatus      @default(available)
  filaments        MakerFilament[]
  printers         MakerPrinter[]
  orders           Order[]
  activeForUser    User?            @relation("ActiveWorkshop")
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  @@index([ownerUserId])
}

/** Принтер в мастерской — из каталога или своя модель */
model MakerPrinter {
  id         String   @id @default(cuid())
  makerId    String
  maker      Maker    @relation(fields: [makerId], references: [id], onDelete: Cascade)
  technology String
  modelKey   String?
  modelLabel String
  isCustom   Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@index([makerId])
}

/** Материал + цвет, которые мейкер добавляет через «+» в кабинете */
model MakerFilament {
  id          String @id @default(cuid())
  makerId     String
  maker       Maker  @relation(fields: [makerId], references: [id], onDelete: Cascade)
  printerType String
  material    String
  color       String

  @@unique([makerId, printerType, material, color])
  @@index([makerId])
}

model Order {
  id                String      @id @default(cuid())
  makerId           String
  maker             Maker       @relation(fields: [makerId], references: [id], onDelete: Restrict)
  customerId        String?
  customer          User?       @relation(fields: [customerId], references: [id], onDelete: SetNull)
  fileName          String
  weightGrams       Float
  widthMm           Float
  heightMm          Float
  depthMm           Float
  printCostCzk      Int
  platformFeeCzk    Int           @default(0)
  customerTotalCzk  Int           @default(0)
  deliveryMethod    String?
  deliveryPriceCzk  Int           @default(0)
  zasilkovnaPointId String?
  zasilkovnaPointLabel String?
  fileUrl           String?
  printQuality      PrintQuality  @default(standard)
  status            OrderStatus   @default(pending)
  messages          OrderMessage[]
  readReceipts      OrderReadReceipt[]
  review            OrderReview?
  dispute           Dispute?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  @@index([makerId])
  @@index([customerId])
  @@index([createdAt])
}

model OrderMessage {
  id        String   @id @default(cuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  senderId  String
  sender    User     @relation(fields: [senderId], references: [id], onDelete: Cascade)
  body      String
  createdAt DateTime @default(now())

  @@index([orderId])
}

/** Kdy uživatel naposledy četl chat u objednávky */
model OrderReadReceipt {
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  orderId    String
  order      Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  lastReadAt DateTime @default(now())

  @@id([userId, orderId])
  @@index([userId])
}

model OrderReview {
  id         String   @id @default(cuid())
  orderId    String   @unique
  order      Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  customerId String
  customer   User     @relation(fields: [customerId], references: [id], onDelete: Cascade)
  rating     Int
  comment    String?
  createdAt  DateTime @default(now())

  @@index([customerId])
}

model Dispute {
  id                  String             @id @default(cuid())
  orderId             String             @unique
  order               Order              @relation(fields: [orderId], references: [id], onDelete: Cascade)
  openedById          String
  openedBy            User               @relation("DisputeOpener", fields: [openedById], references: [id], onDelete: Cascade)
  status              DisputeStatus      @default(open)
  statusBeforeDispute OrderStatus
  complaintText       String
  resolution          DisputeResolution?
  resolutionText      String?
  refundAmountCzk     Int?
  resolvedById        String?
  resolvedBy          User?              @relation("DisputeResolver", fields: [resolvedById], references: [id], onDelete: SetNull)
  resolvedAt          DateTime?
  evidence            DisputeEvidence[]
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  @@index([status])
}

model DisputeEvidence {
  id        String   @id @default(cuid())
  disputeId String
  dispute   Dispute  @relation(fields: [disputeId], references: [id], onDelete: Cascade)
  imageUrl  String
  createdAt DateTime @default(now())

  @@index([disputeId])
}
